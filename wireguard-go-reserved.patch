diff --git a/main.go b/main.go
index b6989e2..f8ef9e4 100644
--- a/main.go
+++ b/main.go
@@ -13,6 +13,7 @@ import (
 	"os/signal"
 	"runtime"
 	"strconv"
+	"strings"
 
 	"golang.org/x/sys/unix"
 	"golang.zx2c4.com/wireguard/conn"
@@ -224,6 +225,30 @@ func main() {
 
 	device := device.NewDevice(tdev, conn.NewDefaultBind(), logger)
 
+	// apply WG_RESERVED env var (e.g. "15,190,193")
+	if reservedStr := os.Getenv("WG_RESERVED"); reservedStr != "" {
+		parts := strings.Split(reservedStr, ",")
+		if len(parts) == 3 {
+			var reserved [3]byte
+			valid := true
+			for i, p := range parts {
+				v, err := strconv.ParseUint(strings.TrimSpace(p), 10, 8)
+				if err != nil {
+					logger.Errorf("Invalid WG_RESERVED byte %q: %v", p, err)
+					valid = false
+					break
+				}
+				reserved[i] = byte(v)
+			}
+			if valid {
+				device.DefaultReserved = reserved
+				logger.Verbosef("Applied reserved bytes: %d,%d,%d", reserved[0], reserved[1], reserved[2])
+			}
+		} else {
+			logger.Errorf("WG_RESERVED must have 3 comma-separated values, got %d", len(parts))
+		}
+	}
+
 	logger.Verbosef("Device started")
 
 	errs := make(chan error)
